---
import type { Article } from "../lib/articles";
import { CATEGORY_LABELS, formatDate } from "../lib/articles";

interface Props {
  article: Article;
}

const { article } = Astro.props;
const cat = CATEGORY_LABELS[article.category];
---

<a
  href={`/articles/${article.slug}/`}
  data-article-slug={article.slug}
  class="article-card group relative block rounded-lg border border-stone-200 dark:border-stone-800 p-5 hover:border-stone-400 dark:hover:border-stone-600 hover:shadow-sm transition"
>
  {/*
    Hidden by default; the late-running script in BaseLayout reads
    engagement state from localStorage and adds `data-status="visited"`
    or `data-status="engaged"` to the card. CSS in global.css then shows
    this checkmark in gray (visited) or green (engaged).
  */}
  <span
    class="read-mark absolute top-3 right-3 inline-flex items-center justify-center w-5 h-5 rounded-full text-white text-[11px] font-bold shadow-sm"
    aria-hidden="true"
  >
    ✓
  </span>
  <div class="flex items-center gap-2 text-xs text-stone-500 dark:text-stone-400 mb-2">
    <span
      class="inline-flex items-center px-2 py-0.5 rounded bg-stone-100 dark:bg-stone-800 text-stone-700 dark:text-stone-300"
    >
      {cat.zh} · {cat.en}
    </span>
    <span>·</span>
    <time datetime={article.publishedAt}>
      {formatDate(article.publishedAt, "zh")}
    </time>
    <span>·</span>
    <span>{article.wordCount} words</span>
  </div>
  <h2
    class="text-lg font-semibold leading-snug text-stone-900 dark:text-stone-100 group-hover:underline"
  >
    {article.title}
  </h2>
  {
    article.subtitle && (
      <p class="mt-1 text-sm text-stone-500 dark:text-stone-400">
        {article.subtitle}
      </p>
    )
  }
  {/*
    Card philosophy:
      Practice mode (default): title + English subtitle only — the subtitle
        is already a one-line elevator pitch, so the card stays clean and
        un-crowded. The reader clicks through to see the full summary.
      Practice mode OFF: also show Chinese summary, since users in this mode
        actively want a quick Chinese preview before deciding to click in.
    The Chinese summary is wrapped in `.zh-spoiler` and hidden by CSS in
    practice mode — see global.css.
  */}
  <p class="zh-spoiler mt-3 text-sm text-stone-700 dark:text-stone-300 line-clamp-3">
    {article.summary.zh}
  </p>
</a>
