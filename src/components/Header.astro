---
import { CATEGORIES, CATEGORY_LABELS } from "../lib/articles";

const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? path === "/" : path.startsWith(href);
---

<header
  class="border-b border-stone-200 bg-white/80 backdrop-blur-sm dark:border-stone-800 dark:bg-stone-950/80 sticky top-0 z-10"
>
  <div class="max-w-5xl mx-auto px-4 py-4 flex items-center justify-between gap-6">
    <a href="/" class="text-lg font-semibold tracking-tight">
      <span class="text-stone-900 dark:text-stone-100">English News</span>
      <span class="text-stone-400 dark:text-stone-500"> / 英文新聞閱讀</span>
    </a>
    <div class="flex items-center gap-4">
      <nav class="hidden md:flex items-center gap-5 text-sm">
        {
          CATEGORIES.map((cat) => (
            <a
              href={`/category/${cat}/`}
              class:list={[
                "transition-colors hover:text-stone-900 dark:hover:text-stone-100",
                isActive(`/category/${cat}`)
                  ? "text-stone-900 dark:text-stone-100 font-medium"
                  : "text-stone-500 dark:text-stone-400",
              ]}
            >
              {CATEGORY_LABELS[cat].zh}
            </a>
          ))
        }
        <a
          href="/about/"
          class:list={[
            "transition-colors hover:text-stone-900 dark:hover:text-stone-100",
            isActive("/about")
              ? "text-stone-900 dark:text-stone-100 font-medium"
              : "text-stone-500 dark:text-stone-400",
          ]}
        >
          關於
        </a>
      </nav>
      {/*
        Search (magnifier) icon — always visible. Links to /search which
        loads Pagefind UI for full-text search across all articles.
      */}
      <a
        href="/search/"
        aria-label="搜尋"
        title="搜尋"
        class:list={[
          "inline-flex items-center justify-center rounded-md p-2 transition-colors hover:bg-stone-100 dark:hover:bg-stone-800",
          isActive("/search")
            ? "text-stone-900 dark:text-stone-100"
            : "text-stone-500 dark:text-stone-400 hover:text-stone-900 dark:hover:text-stone-100",
        ]}
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <circle cx="11" cy="11" r="7"></circle>
          <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
      </a>
      {/*
        Settings (gear) icon — always visible, both desktop and mobile.
        Links to /settings where the user toggles practice mode, font size, etc.
      */}
      <a
        href="/settings/"
        aria-label="設定"
        title="設定"
        class:list={[
          "inline-flex items-center justify-center rounded-md p-2 transition-colors hover:bg-stone-100 dark:hover:bg-stone-800",
          isActive("/settings")
            ? "text-stone-900 dark:text-stone-100"
            : "text-stone-500 dark:text-stone-400 hover:text-stone-900 dark:hover:text-stone-100",
        ]}
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <circle cx="12" cy="12" r="3"></circle>
          <path
            d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"
          ></path>
        </svg>
      </a>
    </div>
  </div>
  <nav class="md:hidden border-t border-stone-200 dark:border-stone-800 overflow-x-auto">
    <div class="flex gap-4 px-4 py-2 text-sm whitespace-nowrap">
      {
        CATEGORIES.map((cat) => (
          <a
            href={`/category/${cat}/`}
            class:list={[
              "transition-colors",
              isActive(`/category/${cat}`)
                ? "text-stone-900 dark:text-stone-100 font-medium"
                : "text-stone-500 dark:text-stone-400",
            ]}
          >
            {CATEGORY_LABELS[cat].zh}
          </a>
        ))
      }
      <a
        href="/about/"
        class:list={[
          "transition-colors",
          isActive("/about")
            ? "text-stone-900 dark:text-stone-100 font-medium"
            : "text-stone-500 dark:text-stone-400",
        ]}
      >
        關於
      </a>
    </div>
  </nav>
</header>
