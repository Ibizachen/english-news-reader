---
import { CATEGORIES, CATEGORY_LABELS } from "../lib/articles";

const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? path === "/" : path.startsWith(href);
---

<header
  class="border-b border-stone-200 bg-white/80 backdrop-blur-sm dark:border-stone-800 dark:bg-stone-950/80 sticky top-0 z-10"
>
  <div class="max-w-5xl mx-auto px-4 py-4 flex items-center justify-between gap-6">
    <a href="/" class="text-lg font-semibold tracking-tight">
      <span class="text-stone-900 dark:text-stone-100">English News</span>
      <span class="text-stone-400 dark:text-stone-500"> / 英文新聞閱讀</span>
    </a>
    <nav class="hidden md:flex items-center gap-5 text-sm">
      {
        CATEGORIES.map((cat) => (
          <a
            href={`/category/${cat}/`}
            class:list={[
              "transition-colors hover:text-stone-900 dark:hover:text-stone-100",
              isActive(`/category/${cat}`)
                ? "text-stone-900 dark:text-stone-100 font-medium"
                : "text-stone-500 dark:text-stone-400",
            ]}
          >
            {CATEGORY_LABELS[cat].zh}
          </a>
        ))
      }
      <a
        href="/about/"
        class:list={[
          "transition-colors hover:text-stone-900 dark:hover:text-stone-100",
          isActive("/about")
            ? "text-stone-900 dark:text-stone-100 font-medium"
            : "text-stone-500 dark:text-stone-400",
        ]}
      >
        關於
      </a>
    </nav>
  </div>
  <nav class="md:hidden border-t border-stone-200 dark:border-stone-800 overflow-x-auto">
    <div class="flex gap-4 px-4 py-2 text-sm whitespace-nowrap">
      {
        CATEGORIES.map((cat) => (
          <a
            href={`/category/${cat}/`}
            class:list={[
              "transition-colors",
              isActive(`/category/${cat}`)
                ? "text-stone-900 dark:text-stone-100 font-medium"
                : "text-stone-500 dark:text-stone-400",
            ]}
          >
            {CATEGORY_LABELS[cat].zh}
          </a>
        ))
      }
      <a
        href="/about/"
        class:list={[
          "transition-colors",
          isActive("/about")
            ? "text-stone-900 dark:text-stone-100 font-medium"
            : "text-stone-500 dark:text-stone-400",
        ]}
      >
        關於
      </a>
    </div>
  </nav>
</header>
