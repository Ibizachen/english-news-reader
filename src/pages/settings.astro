---
export const prerender = true;
import BaseLayout from "../layouts/BaseLayout.astro";
import SettingsPanel from "../components/SettingsPanel.tsx";
---

<BaseLayout title="設定" description="調整閱讀偏好與顯示選項">
  <article class="max-w-3xl mx-auto px-4 pt-10 pb-16">
    <h1 class="text-2xl md:text-3xl font-bold tracking-tight mb-2">設定</h1>
    <p class="text-stone-500 dark:text-stone-400 mb-8">
      Settings · 調整這個瀏覽器上的閱讀偏好
    </p>
    <SettingsPanel client:load />
  </article>
</BaseLayout>
