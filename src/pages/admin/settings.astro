---
export const prerender = false;
import BaseLayout from "../../layouts/BaseLayout.astro";
import SettingsForm from "../../components/admin/SettingsForm";
import { readSettings, isUsingDefaults } from "../../lib/aiSettings";

const initial = readSettings();
const usingDefaults = isUsingDefaults();
---

<BaseLayout
  title="管理 · AI Pipeline 設定"
  description="本機管理頁面：設定 AI 流水線各階段的 provider 與 model"
>
  <main class="max-w-4xl mx-auto px-4 pt-10 pb-16">
    <div class="mb-2">
      <p class="text-xs text-stone-500 dark:text-stone-400">/admin/settings</p>
    </div>
    <h1 class="text-2xl md:text-3xl font-bold tracking-tight">
      AI Pipeline 設定
    </h1>
    <p class="mt-2 text-sm text-stone-600 dark:text-stone-400">
      四個 AI 階段（選題、合成、翻譯、出題）可以各自獨立指定 provider 與 model。
      存檔後會寫入 <code>data/config/ai_settings.json</code>，下次跑 <code>uv run python scripts/ai_pipeline.py</code> 就會用新設定。
    </p>

    <div
      class="mt-4 rounded-md border border-stone-200 dark:border-stone-800 bg-stone-50/60 dark:bg-stone-900/40 p-3 text-xs text-stone-600 dark:text-stone-400"
    >
      <strong>注意</strong>：這個頁面只在你本機 <code>npm run dev</code> 啟動時才存在；部署到 Cloudflare 後不會公開。
      所以可以放心調整，不會影響線上網站。
    </div>

    <div class="mt-6">
      <SettingsForm
        client:load
        initialSettings={initial}
        initiallyUsingDefaults={usingDefaults}
      />
    </div>
  </main>
</BaseLayout>
