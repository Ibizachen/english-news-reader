---
export const prerender = true;
import BaseLayout from "../layouts/BaseLayout.astro";
import ArticleCard from "../components/ArticleCard.astro";
import { CATEGORIES, CATEGORY_LABELS, getLocalDate, loadFeedArticles } from "../lib/articles";

const articles = loadFeedArticles();
// Group "today's" articles = all from the most recent date in Asia/Taipei time.
const latestDate = articles[0] ? getLocalDate(articles[0].publishedAt) : undefined;
const latest = latestDate
  ? articles.filter((a) => getLocalDate(a.publishedAt) === latestDate)
  : [];

// "Earlier" section shows the LAST 7 DAYS of articles, grouped by date.
// Older than 7 days lives only on /archive — keeps the homepage feeling
// like a current-news feed rather than a sitemap. As content scales to
// hundreds/thousands of articles, the homepage stays fast.
const HOMEPAGE_EARLIER_DAYS = 7;
const olderByDate = articles
  .filter((a) => getLocalDate(a.publishedAt) !== latestDate)
  .reduce<Record<string, typeof articles>>((acc, a) => {
    const date = getLocalDate(a.publishedAt);
    (acc[date] ||= []).push(a);
    return acc;
  }, {});
const olderDates = Object.keys(olderByDate)
  .sort()
  .reverse()
  .slice(0, HOMEPAGE_EARLIER_DAYS);
// Show the "browse all articles" link whenever there's at least 1 older
// article worth digging into. Earlier we gated this on >7 day overflow,
// but that means new visitors don't discover the archive page until
// after a week. Better: surface it as soon as there's any back catalog.
const hasEvenOlder = articles.length > latest.length;
---

<BaseLayout
  title="英文新聞閱讀"
  description="每天 4-5 篇 AI 綜合新聞，含中英對照與選擇題練習"
>
  <section class="max-w-5xl mx-auto px-4 pt-10 pb-6">
    <h1 class="text-2xl md:text-3xl font-bold tracking-tight">
      今日新聞 · Today's articles
    </h1>
    <p class="mt-2 text-stone-600 dark:text-stone-400">
      閱讀英文新聞、做選擇題練習，並對照中文翻譯。
    </p>
  </section>

  <section class="max-w-5xl mx-auto px-4 pb-10">
    {
      latest.length === 0 ? (
        <div class="rounded-lg border border-dashed border-stone-300 dark:border-stone-700 p-8 text-center text-stone-500">
          目前還沒有文章。請執行 Phase 2 / 3 的腳本產生文章，或先用 Phase 1 的 mock 資料瀏覽。
        </div>
      ) : (
        <div class="grid gap-4 md:grid-cols-2">
          {latest.map((a) => (
            <ArticleCard article={a} />
          ))}
        </div>
      )
    }
  </section>

  {/*
    Section order: today → earlier → categories.
    Reasoning: visitors come for today's news first, then want to scroll
    through what they may have missed (earlier days). Categories live at
    the bottom as a navigation aid for those who want to dig deeper.
  */}
  {
    olderDates.length > 0 && (
      <section class="max-w-5xl mx-auto px-4 pb-10">
        <h2 class="text-xl font-semibold mb-4">過往文章 · Earlier</h2>
        {olderDates.map((date) => (
          <div class="mb-8">
            <h3 class="text-sm font-medium text-stone-500 dark:text-stone-400 mb-3">
              {date}
            </h3>
            <div class="grid gap-4 md:grid-cols-2">
              {olderByDate[date].map((a) => (
                <ArticleCard article={a} />
              ))}
            </div>
          </div>
        ))}
        {hasEvenOlder && (
          <div class="mt-2">
            <a
              href="/archive/"
              class="inline-flex items-center gap-2 text-sm rounded-md border border-stone-300 dark:border-stone-700 px-4 py-2 text-stone-700 dark:text-stone-300 hover:bg-stone-50 dark:hover:bg-stone-900 transition"
            >
              📚 查看完整文章庫 · Browse all articles
              <span aria-hidden="true">→</span>
            </a>
          </div>
        )}
      </section>
    )
  }

  <section class="max-w-5xl mx-auto px-4 pb-16">
    <h2 class="text-xl font-semibold mb-4">瀏覽分類 · Browse categories</h2>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
      {
        CATEGORIES.map((cat) => (
          <a
            href={`/category/${cat}/`}
            class="rounded-lg border border-stone-200 dark:border-stone-800 p-4 text-center hover:border-stone-400 dark:hover:border-stone-600 transition"
          >
            <div class="font-semibold">{CATEGORY_LABELS[cat].zh}</div>
            <div class="text-xs text-stone-500 dark:text-stone-400 mt-0.5">
              {CATEGORY_LABELS[cat].en}
            </div>
          </a>
        ))
      }
    </div>
  </section>
</BaseLayout>
