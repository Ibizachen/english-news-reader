---
// Static mode: every article slug is prerendered at build time. Whenever
// new articles land in data/published/ and we re-build, fresh HTML is
// generated for them.
//
// Local dev still gets fresh content immediately (Vite re-evaluates the
// module on file change because we removed the loadArticles cache).
import BaseLayout from "../../layouts/BaseLayout.astro";
import BilingualReader from "../../components/BilingualReader.tsx";
import Quiz from "../../components/Quiz.tsx";
import {
  CATEGORY_LABELS,
  formatDate,
  formatDateTime,
  loadArticles,
} from "../../lib/articles";
import { getStoriesForArticle } from "../../lib/stories";

export function getStaticPaths() {
  return loadArticles().map((article) => ({
    params: { slug: article.slug },
    props: { article },
  }));
}

const { article } = Astro.props;
const cat = CATEGORY_LABELS[article.category];
const articleStories = getStoriesForArticle(article.slug);
---

<BaseLayout title={article.title} description={article.summary.en}>
  <article id="article-top" class="max-w-3xl mx-auto px-4 pt-10 pb-16 scroll-mt-24">
    <div class="text-xs text-stone-500 dark:text-stone-400 flex items-center gap-2 flex-wrap">
      <a
        href={`/category/${article.category}/`}
        class="inline-flex items-center px-2 py-0.5 rounded bg-stone-100 dark:bg-stone-800 text-stone-700 dark:text-stone-300 hover:bg-stone-200 dark:hover:bg-stone-700"
      >
        {cat.zh} · {cat.en}
      </a>
      <span>·</span>
      <time datetime={article.publishedAt}>
        {formatDate(article.publishedAt, "zh")}
      </time>
      <span>·</span>
      <span>{article.wordCount} words · {article.readingLevel}</span>
    </div>

    <h1 class="mt-3 text-3xl md:text-4xl font-bold tracking-tight leading-tight">
      {article.title}
    </h1>
    {
      article.subtitle && (
        <p class="mt-2 text-lg text-stone-600 dark:text-stone-400">
          {article.subtitle}
        </p>
      )
    }

    <p class="mt-3 text-xs text-stone-500 dark:text-stone-400">
      🕒 生成時間：
      <time datetime={article.publishedAt}>
        {formatDateTime(article.publishedAt, "zh")}
      </time>
      <span class="text-stone-400 dark:text-stone-500">（台北時間）</span>
    </p>

    <div
      class="mt-6 rounded-md bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 p-3 text-sm text-amber-900 dark:text-amber-200"
    >
      ⚠️ {article.aiDisclaimer}
    </div>

    {/*
      The English summary is always visible. The Chinese summary is wrapped
      in `.zh-spoiler` — practice mode (default) hides it so the reader
      practises English without a translation spoiler. /settings toggles it.
    */}
    <section class="mt-8 rounded-md border border-stone-200 dark:border-stone-800 p-4 bg-stone-50/50 dark:bg-stone-900/30">
      <p class="text-xs uppercase tracking-wide text-stone-500 dark:text-stone-400 mb-1">
        Summary · 摘要
      </p>
      <p class="text-stone-800 dark:text-stone-200 leading-relaxed mb-2">
        {article.summary.en}
      </p>
      <p class="zh-spoiler text-stone-600 dark:text-stone-300 text-sm leading-relaxed">
        {article.summary.zh}
      </p>
    </section>

    {
      articleStories.length > 0 && (
        <section class="mt-4 rounded-md border border-emerald-200 dark:border-emerald-900 bg-emerald-50/60 dark:bg-emerald-950/20 p-4">
          <p class="text-xs uppercase tracking-wide text-emerald-700 dark:text-emerald-300 mb-2">
            Stories · 追蹤專題
          </p>
          <ul class="space-y-2">
            {articleStories.map((story) => (
              <li class="text-sm">
                <a
                  href={`/stories/${story.id}/`}
                  class="font-medium text-stone-800 dark:text-stone-100 hover:underline"
                >
                  {story.title}
                </a>
                <span class="text-stone-500 dark:text-stone-400">
                  {" "}
                  · {story.resolvedArticles.length} 篇閱讀路徑
                </span>
              </li>
            ))}
          </ul>
        </section>
      )
    }

    {
      article.story?.type === "update" &&
        article.story.previousArticles.length > 0 && (
          <section class="mt-4 rounded-md border border-sky-200 dark:border-sky-900 bg-sky-50/60 dark:bg-sky-950/20 p-4">
            <p class="text-xs uppercase tracking-wide text-sky-700 dark:text-sky-300 mb-2">
              Ongoing story · 追蹤中的新聞
            </p>
            <p class="text-sm text-stone-700 dark:text-stone-300 mb-3">
              This article follows earlier coverage on the same developing story.
            </p>
            <ul class="space-y-2">
              {article.story.previousArticles.map((prev) => (
                <li class="text-sm">
                  <a
                    href={`/articles/${prev.slug}/`}
                    class="font-medium text-stone-800 dark:text-stone-100 hover:underline"
                  >
                    {prev.title}
                  </a>
                  <span class="text-stone-500 dark:text-stone-400">
                    {" "}
                    · {formatDate(prev.publishedAt, "zh")}
                  </span>
                  {prev.summaryEn && (
                    <p class="mt-0.5 text-xs text-stone-500 dark:text-stone-400 line-clamp-2">
                      {prev.summaryEn}
                    </p>
                  )}
                </li>
              ))}
            </ul>
          </section>
        )
    }

    {
      article.keyTerms.length > 0 && (
        <div class="mt-4 flex justify-end">
          <a
            href="#words-to-watch"
            class="inline-flex items-center gap-1.5 text-sm rounded-full border border-amber-300 dark:border-amber-700 bg-amber-50 dark:bg-amber-900/20 px-3 py-1.5 text-amber-800 dark:text-amber-200 hover:bg-amber-100 dark:hover:bg-amber-900/40 transition"
          >
            <span aria-hidden="true">💡</span>
            閱讀前先看「易誤解詞彙」
            <span aria-hidden="true">↓</span>
          </a>
        </div>
      )
    }

    <section class="mt-10">
      <BilingualReader client:load paragraphs={article.paragraphs} />
      {/*
        Sentinel: when this element scrolls into view, the user has read
        through the entire article body. The inline script below uses
        IntersectionObserver to mark this article as read in localStorage.
      */}
      <div data-read-sentinel aria-hidden="true" class="h-1"></div>
    </section>

    {/*
      Section order on the article page (v2.4.0+):
        1. Article body (BilingualReader)
        2. Quiz                        ← moved up so it's not spoiled by Words
        3. Words to Watch              ← reference material, looked up after
        4. Sources

      Why: quiz often tests vocabulary that overlaps with the Words to Watch
      list. Showing definitions before the quiz lets readers cheat their way
      through. Quiz first means readers see whether they actually know the
      tricky words; the definitions then serve as targeted study material.
      The "易誤解詞彙" jump button at the top of the page still links to
      #words-to-watch — it just lands further down the page now.
    */}

    <Quiz client:load questions={article.quiz} slug={article.slug} />

    {
      article.keyTerms.length > 0 && (
        <section
          id="words-to-watch"
          class="mt-12 border-t border-stone-200 dark:border-stone-800 pt-8 scroll-mt-24"
        >
          <h2 class="text-xl font-bold mb-1">易誤解詞彙 · Words to watch</h2>
          <p class="text-sm text-stone-500 dark:text-stone-400 mb-4">
            這些字字面意思和文中用法不同，或是不常見的詞性／片語。
          </p>
          <dl class="space-y-3">
            {article.keyTerms.map((kt) => (
              <div class="rounded-md border border-stone-200 dark:border-stone-800 p-3">
                <dt class="font-semibold flex items-baseline gap-2 flex-wrap">
                  <span>{kt.term}</span>
                  {kt.partOfSpeech && (
                    <span class="text-xs font-normal text-stone-500 dark:text-stone-400 italic">
                      {kt.partOfSpeech}
                    </span>
                  )}
                </dt>
                <dd class="text-sm text-stone-700 dark:text-stone-300 mt-1">
                  {kt.definitionEn}
                </dd>
                <dd class="text-sm text-stone-600 dark:text-stone-300 mt-0.5">
                  {kt.definitionZh}
                </dd>
                {kt.noteZh && (
                  <dd class="text-xs text-stone-500 dark:text-stone-400 mt-2 border-l-2 border-amber-400 dark:border-amber-600 pl-2">
                    💡 {kt.noteZh}
                  </dd>
                )}
              </div>
            ))}
          </dl>
          <div class="mt-5 text-right">
            <a
              href="#article-top"
              class="inline-flex items-center gap-1 text-sm text-stone-600 dark:text-stone-400 hover:text-stone-900 dark:hover:text-stone-100 hover:underline"
            >
              <span aria-hidden="true">↑</span>
              回到文章開頭開始閱讀
            </a>
          </div>
        </section>
      )
    }

    <section class="mt-12 border-t border-stone-200 dark:border-stone-800 pt-8">
      <h2 class="text-xl font-bold mb-4">原始來源 · Sources</h2>
      <p class="text-sm text-stone-500 dark:text-stone-400 mb-4">
        本文內容由 AI 從以下來源綜合改寫。事實請以原始來源為準。
      </p>
      <ul class="space-y-2">
        {
          article.sources.map((src) => (
            <li class="text-sm">
              <a
                href={src.url}
                target="_blank"
                rel="noopener noreferrer"
                class="text-stone-700 dark:text-stone-300 hover:underline break-words"
              >
                <strong class="text-stone-900 dark:text-stone-100">
                  {src.name}
                </strong>{" "}
                — {src.title}
              </a>{" "}
              <span class="text-stone-400 dark:text-stone-500">
                ({formatDate(src.publishedAt, "en")})
              </span>
            </li>
          ))
        }
      </ul>
    </section>

    <section class="mt-10 text-xs text-stone-500 dark:text-stone-400 border-t border-stone-200 dark:border-stone-800 pt-4">
      Generated by: <code>{article.aiModel}</code>
    </section>
  </article>

  {/*
    Engagement tracker (v2.4.0):
      1. On page load — mark `enr.visited[slug]` = NOW (gray ✓ on cards)
      2. When sentinel scrolls into view — mark `enr.read[slug]` = NOW
         (combines with quiz score for green ✓)

    Both marks only record the FIRST occurrence so streaks/timestamps stay
    meaningful across re-reads. See src/lib/preferences.ts for the schema.
  */}
  <script is:inline define:vars={{ slug: article.slug }}>
    (function () {
      // Generic "set this slug in this dict if missing" helper.
      function recordOnce(key) {
        try {
          var raw = localStorage.getItem(key);
          var dict = raw ? JSON.parse(raw) : {};
          if (!dict || typeof dict !== "object") dict = {};
          if (dict[slug]) return; // keep first timestamp
          dict[slug] = new Date().toISOString();
          localStorage.setItem(key, JSON.stringify(dict));
        } catch (e) {
          // ignore (private mode, etc.)
        }
      }

      // 1. Page loaded → mark as visited immediately.
      recordOnce("enr.visited");

      // 2. Watch sentinel for "scrolled to bottom of body" → mark as read.
      var sentinel = document.querySelector("[data-read-sentinel]");
      if (!sentinel || !("IntersectionObserver" in window)) return;
      var observer = new IntersectionObserver(
        function (entries) {
          for (var i = 0; i < entries.length; i++) {
            if (entries[i].isIntersecting) {
              recordOnce("enr.read");
              observer.disconnect();
              return;
            }
          }
        },
        { threshold: 0 },
      );
      observer.observe(sentinel);
    })();
  </script>
</BaseLayout>
