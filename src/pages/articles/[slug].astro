---
// Static mode: every article slug is prerendered at build time. Whenever
// new articles land in data/published/ and we re-build, fresh HTML is
// generated for them.
//
// Local dev still gets fresh content immediately (Vite re-evaluates the
// module on file change because we removed the loadArticles cache).
import BaseLayout from "../../layouts/BaseLayout.astro";
import BilingualReader from "../../components/BilingualReader.tsx";
import Quiz from "../../components/Quiz.tsx";
import {
  CATEGORY_LABELS,
  formatDate,
  formatDateTime,
  loadArticles,
} from "../../lib/articles";

export function getStaticPaths() {
  return loadArticles().map((article) => ({
    params: { slug: article.slug },
    props: { article },
  }));
}

const { article } = Astro.props;
const cat = CATEGORY_LABELS[article.category];
---

<BaseLayout title={article.title} description={article.summary.en}>
  <article id="article-top" class="max-w-3xl mx-auto px-4 pt-10 pb-16 scroll-mt-24">
    <div class="text-xs text-stone-500 dark:text-stone-400 flex items-center gap-2 flex-wrap">
      <a
        href={`/category/${article.category}/`}
        class="inline-flex items-center px-2 py-0.5 rounded bg-stone-100 dark:bg-stone-800 text-stone-700 dark:text-stone-300 hover:bg-stone-200 dark:hover:bg-stone-700"
      >
        {cat.zh} · {cat.en}
      </a>
      <span>·</span>
      <time datetime={article.publishedAt}>
        {formatDate(article.publishedAt, "zh")}
      </time>
      <span>·</span>
      <span>{article.wordCount} words · {article.readingLevel}</span>
    </div>

    <h1 class="mt-3 text-3xl md:text-4xl font-bold tracking-tight leading-tight">
      {article.title}
    </h1>
    {
      article.subtitle && (
        <p class="mt-2 text-lg text-stone-600 dark:text-stone-400">
          {article.subtitle}
        </p>
      )
    }

    <p class="mt-3 text-xs text-stone-500 dark:text-stone-400">
      🕒 生成時間：
      <time datetime={article.publishedAt}>
        {formatDateTime(article.publishedAt, "zh")}
      </time>
      <span class="text-stone-400 dark:text-stone-500">（台北時間）</span>
    </p>

    <div
      class="mt-6 rounded-md bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 p-3 text-sm text-amber-900 dark:text-amber-200"
    >
      ⚠️ {article.aiDisclaimer}
    </div>

    <section class="mt-8 rounded-md border border-stone-200 dark:border-stone-800 p-4 bg-stone-50/50 dark:bg-stone-900/30">
      <p class="text-xs uppercase tracking-wide text-stone-500 dark:text-stone-400 mb-1">
        Summary · 摘要
      </p>
      <p class="text-stone-800 dark:text-stone-200 leading-relaxed mb-2">
        {article.summary.en}
      </p>
      <p class="text-stone-600 dark:text-stone-300 text-sm leading-relaxed">
        {article.summary.zh}
      </p>
    </section>

    {
      article.keyTerms.length > 0 && (
        <div class="mt-4 flex justify-end">
          <a
            href="#words-to-watch"
            class="inline-flex items-center gap-1.5 text-sm rounded-full border border-amber-300 dark:border-amber-700 bg-amber-50 dark:bg-amber-900/20 px-3 py-1.5 text-amber-800 dark:text-amber-200 hover:bg-amber-100 dark:hover:bg-amber-900/40 transition"
          >
            <span aria-hidden="true">💡</span>
            閱讀前先看「易誤解詞彙」
            <span aria-hidden="true">↓</span>
          </a>
        </div>
      )
    }

    <section class="mt-10">
      <BilingualReader client:load paragraphs={article.paragraphs} />
    </section>

    {
      article.keyTerms.length > 0 && (
        <section
          id="words-to-watch"
          class="mt-12 border-t border-stone-200 dark:border-stone-800 pt-8 scroll-mt-24"
        >
          <h2 class="text-xl font-bold mb-1">易誤解詞彙 · Words to watch</h2>
          <p class="text-sm text-stone-500 dark:text-stone-400 mb-4">
            這些字字面意思和文中用法不同，或是不常見的詞性／片語。
          </p>
          <dl class="space-y-3">
            {article.keyTerms.map((kt) => (
              <div class="rounded-md border border-stone-200 dark:border-stone-800 p-3">
                <dt class="font-semibold flex items-baseline gap-2 flex-wrap">
                  <span>{kt.term}</span>
                  {kt.partOfSpeech && (
                    <span class="text-xs font-normal text-stone-500 dark:text-stone-400 italic">
                      {kt.partOfSpeech}
                    </span>
                  )}
                </dt>
                <dd class="text-sm text-stone-700 dark:text-stone-300 mt-1">
                  {kt.definitionEn}
                </dd>
                <dd class="text-sm text-stone-600 dark:text-stone-300 mt-0.5">
                  {kt.definitionZh}
                </dd>
                {kt.noteZh && (
                  <dd class="text-xs text-stone-500 dark:text-stone-400 mt-2 border-l-2 border-amber-400 dark:border-amber-600 pl-2">
                    💡 {kt.noteZh}
                  </dd>
                )}
              </div>
            ))}
          </dl>
          <div class="mt-5 text-right">
            <a
              href="#article-top"
              class="inline-flex items-center gap-1 text-sm text-stone-600 dark:text-stone-400 hover:text-stone-900 dark:hover:text-stone-100 hover:underline"
            >
              <span aria-hidden="true">↑</span>
              回到文章開頭開始閱讀
            </a>
          </div>
        </section>
      )
    }

    <Quiz client:load questions={article.quiz} />

    <section class="mt-12 border-t border-stone-200 dark:border-stone-800 pt-8">
      <h2 class="text-xl font-bold mb-4">原始來源 · Sources</h2>
      <p class="text-sm text-stone-500 dark:text-stone-400 mb-4">
        本文內容由 AI 從以下來源綜合改寫。事實請以原始來源為準。
      </p>
      <ul class="space-y-2">
        {
          article.sources.map((src) => (
            <li class="text-sm">
              <a
                href={src.url}
                target="_blank"
                rel="noopener noreferrer"
                class="text-stone-700 dark:text-stone-300 hover:underline break-words"
              >
                <strong class="text-stone-900 dark:text-stone-100">
                  {src.name}
                </strong>{" "}
                — {src.title}
              </a>{" "}
              <span class="text-stone-400 dark:text-stone-500">
                ({formatDate(src.publishedAt, "en")})
              </span>
            </li>
          ))
        }
      </ul>
    </section>

    <section class="mt-10 text-xs text-stone-500 dark:text-stone-400 border-t border-stone-200 dark:border-stone-800 pt-4">
      Generated by: <code>{article.aiModel}</code>
    </section>
  </article>
</BaseLayout>
