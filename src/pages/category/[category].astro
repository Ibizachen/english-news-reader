---
// Category landing page (page 1) at /category/{cat}/.
// Pages 2+ live at /category/{cat}/page/2/, etc.
// See src/pages/category/[category]/page/[page].astro for those.
//
// Mirrors the /archive/ pagination pattern: keeps /category/{cat}/ as a
// stable URL that the header & homepage link to, with a [page] dynamic
// route hanging off it for the long tail.
export const prerender = true;
import BaseLayout from "../../layouts/BaseLayout.astro";
import ArticleCard from "../../components/ArticleCard.astro";
import {
  CATEGORIES,
  CATEGORY_LABELS,
  getArticlesByCategory,
} from "../../lib/articles";
import type { Category } from "../../lib/articles";

const PAGE_SIZE = 20;

export function getStaticPaths() {
  return CATEGORIES.map((cat) => ({ params: { category: cat } }));
}

const { category } = Astro.params as { category: Category };
const label = CATEGORY_LABELS[category];
const allArticles = getArticlesByCategory(category);
const totalArticles = allArticles.length;
const totalPages = Math.max(1, Math.ceil(totalArticles / PAGE_SIZE));
const currentPage = 1;
const pageArticles = allArticles.slice(0, PAGE_SIZE);
---

<BaseLayout
  title={`${label.zh} ${label.en}`}
  description={`${label.zh} 分類的英文新聞文章`}
>
  <section class="max-w-5xl mx-auto px-4 pt-10 pb-6">
    <p class="text-sm text-stone-500 dark:text-stone-400">分類 · Category</p>
    <h1 class="mt-1 text-2xl md:text-3xl font-bold tracking-tight">
      {label.zh} <span class="text-stone-400 dark:text-stone-500">/ {label.en}</span>
    </h1>
    <p class="mt-2 text-stone-600 dark:text-stone-400">
      {totalArticles === 0
        ? "尚無文章"
        : `共 ${totalArticles} 篇文章${totalPages > 1 ? `，第 ${currentPage} 頁 / 共 ${totalPages} 頁` : ""}`}
    </p>
  </section>

  <section class="max-w-5xl mx-auto px-4 pb-10">
    {totalArticles === 0 ? (
      <div class="rounded-lg border border-dashed border-stone-300 dark:border-stone-700 p-8 text-center text-stone-500">
        這個分類下還沒有文章。
      </div>
    ) : (
      <div class="grid gap-4 md:grid-cols-2">
        {pageArticles.map((a) => <ArticleCard article={a} />)}
      </div>
    )}
  </section>

  {totalPages > 1 && (
    <section class="max-w-5xl mx-auto px-4 pb-16">
      <nav
        aria-label="分頁導覽"
        class="flex items-center justify-between gap-3 border-t border-stone-200 dark:border-stone-800 pt-6"
      >
        <span class="text-sm text-stone-400 dark:text-stone-500">
          第 {currentPage} 頁 / 共 {totalPages} 頁
        </span>
        <a
          href={`/category/${category}/page/${currentPage + 1}/`}
          class="inline-flex items-center gap-2 text-sm rounded-md border border-stone-300 dark:border-stone-700 px-4 py-2 text-stone-700 dark:text-stone-300 hover:bg-stone-50 dark:hover:bg-stone-900 transition"
        >
          下一頁 · Next
          <span aria-hidden="true">→</span>
        </a>
      </nav>
    </section>
  )}
</BaseLayout>
