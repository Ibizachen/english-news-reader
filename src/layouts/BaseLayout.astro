---
import "../styles/global.css";
import Header from "../components/Header.astro";

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
const fullTitle = title === "英文新聞閱讀" ? title : `${title} | 英文新聞閱讀`;
---

<!doctype html>
<html lang="zh-Hant">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    {description && <meta name="description" content={description} />}
    <title>{fullTitle}</title>
    <!--
      Read user preferences from localStorage BEFORE first paint to avoid
      a flash of wrong content. Adds classes to <html>:
        practice-mode          — default ON unless user explicitly turned off
        text-small|medium|large — default medium
        bilingual-responsive   — opt-in side-by-side layout on desktop
                                 (default = vertical / stacked)
      See src/styles/global.css for the matching rules.
    -->
    <script is:inline>
      (function () {
        try {
          var practice = localStorage.getItem("enr.practiceMode");
          // Default = ON: hide Chinese summary unless user explicitly opted out.
          if (practice !== "false") {
            document.documentElement.classList.add("practice-mode");
          }
          var size = localStorage.getItem("enr.fontSize");
          if (size !== "small" && size !== "large") size = "medium";
          document.documentElement.classList.add("text-" + size);

          // Default = vertical (no class). Only add the class if user chose responsive.
          if (localStorage.getItem("enr.bilingualLayout") === "responsive") {
            document.documentElement.classList.add("bilingual-responsive");
          }
        } catch (e) {
          // localStorage may be blocked (private mode, etc.) — fall back to defaults.
          document.documentElement.classList.add("practice-mode", "text-medium");
        }
      })();
    </script>
  </head>
  <body class="min-h-screen flex flex-col">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <footer
      class="border-t border-stone-200 dark:border-stone-800 mt-16 py-8 text-center text-sm text-stone-500 dark:text-stone-400"
    >
      <div class="max-w-5xl mx-auto px-4 space-y-2">
        <p>
          每篇文章皆為 AI 從多個原始新聞來源綜合生成，<strong>不是逐字翻譯也不是新聞原文轉貼</strong>。事實請以原始來源為準。
        </p>
        <p>
          <a href="/about/" class="underline hover:text-stone-700 dark:hover:text-stone-200">了解更多</a>
        </p>
      </div>
    </footer>
    <!--
      Late script (after DOM is parsed) — reads engagement state from
      localStorage and stamps `data-status="visited"` or `"engaged"` on
      every <a.article-card>. CSS in global.css then shows a gray ✓ for
      visited and a green ✓ for engaged.

      Engagement rules (v2.4.0):
        engaged = scrolled past sentinel AND completed quiz
        visited = page loaded (or, for legacy data, scrolled past sentinel)

      Runs on every page; safely no-ops on pages without cards.
    -->
    <script is:inline>
      (function () {
        function loadDict(key) {
          try {
            var raw = localStorage.getItem(key);
            if (!raw) return {};
            var parsed = JSON.parse(raw);
            return parsed && typeof parsed === "object" ? parsed : {};
          } catch (e) {
            return {};
          }
        }
        var visited = loadDict("enr.visited");
        var read = loadDict("enr.read");
        var scores = loadDict("enr.scores");

        var cards = document.querySelectorAll("[data-article-slug]");
        for (var i = 0; i < cards.length; i++) {
          var slug = cards[i].getAttribute("data-article-slug");
          if (!slug) continue;
          var hasRead = !!read[slug];
          var hasScore = !!scores[slug];
          // `read` implies user must have visited (you can't scroll without
          // loading the page) — gives backwards compat for users with data
          // from v2.1–v2.3 that pre-dates the `enr.visited` key.
          var hasVisited = !!visited[slug] || hasRead;

          if (hasRead && hasScore) {
            cards[i].setAttribute("data-status", "engaged");
          } else if (hasVisited) {
            cards[i].setAttribute("data-status", "visited");
          }
        }
      })();
    </script>
  </body>
</html>
